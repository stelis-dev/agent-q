# Build scripts and CI source this file so this hardware-specific external
# firmware dependency is pinned in tracked repository state instead of in a
# local .WORK checkout.

STACKCHAN_REPOSITORY=https://github.com/m5stack/StackChan.git
STACKCHAN_COMMIT=da156e1fa0e1c2a5e00b78fbf69b1f7e7bca0483
ESP_IDF_VERSION=v5.5.4
