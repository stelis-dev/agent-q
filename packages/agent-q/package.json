{
  "name": "@stelis/agent-q",
  "version": "0.0.0",
  "description": "Agent-Q local server with MCP API, local Admin Page, and Sui CLI external signer support.",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/stelis-dev/agent-q.git",
    "directory": "packages/agent-q"
  },
  "main": "./dist/mcp.js",
  "types": "./dist/mcp.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "agent-q": "./dist/bin/agent-q.js",
    "agent-q-sui-signer": "./dist/bin/agent-q-sui-signer.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "npm --workspace @stelis/agent-q-core run build",
    "build": "npm run build:self",
    "build:self": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && chmod +x dist/bin/agent-q.js dist/bin/agent-q-sui-signer.js",
    "test": "npm run build && npm run test:self",
    "test:self": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@stelis/agent-q-core": "0.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
