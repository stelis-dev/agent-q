{
  "name": "@stelis/agent-q-client",
  "version": "0.0.0",
  "description": "Device-facing Agent-Q client for USB-connected Firmware discovery, sessions, and protocol requests.",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/stelis-dev/agent-q.git",
    "directory": "packages/client"
  },
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js"
    },
    "./adapter-internal": {
      "types": "./dist/adapter-internal.d.ts",
      "import": "./dist/adapter-internal.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./provider-protocol": {
      "types": "./dist/provider-protocol.d.ts",
      "import": "./dist/provider-protocol.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "serialport": "13.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
