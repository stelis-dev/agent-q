{
  "name": "@stelis/agent-q-core",
  "version": "0.1.2",
  "description": "Agent-Q core library for USB device discovery, protocol transport, runtime session mirroring, and Firmware-authored result validation.",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/stelis-dev/agent-q.git",
    "directory": "packages/core"
  },
  "main": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./device": {
      "types": "./dist/device.d.ts",
      "import": "./dist/device.js"
    },
    "./adapter-internal": {
      "types": "./dist/adapter-internal.d.ts",
      "import": "./dist/adapter-internal.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./provider-protocol": {
      "types": "./dist/provider-protocol.d.ts",
      "import": "./dist/provider-protocol.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:self",
    "build:self": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test": "npm run build && npm run test:self",
    "test:self": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "serialport": "13.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
