{
  "name": "@stelis/agent-q-provider-sui",
  "version": "0.2.0",
  "description": "Sui provider and Wallet Standard adapter that route app signing requests to Agent-Q Firmware through the host process.",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/stelis-dev/agent-q.git",
    "directory": "packages/provider-sui"
  },
  "main": "./dist/provider-sui.js",
  "types": "./dist/provider-sui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/provider-sui.d.ts",
      "import": "./dist/provider-sui.js",
      "default": "./dist/provider-sui.js"
    },
    "./provider-sui": {
      "types": "./dist/provider-sui.d.ts",
      "import": "./dist/provider-sui.js",
      "default": "./dist/provider-sui.js"
    },
    "./wallet-standard": {
      "types": "./dist/wallet-standard.d.ts",
      "import": "./dist/wallet-standard.js",
      "default": "./dist/wallet-standard.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "npm --workspace @stelis/agent-q-core run build",
    "build": "npm run build:self",
    "build:self": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test": "npm run build && npm run test:self",
    "test:self": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "@mysten/wallet-standard": "^0.20.3",
    "@stelis/agent-q-core": "0.2.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
