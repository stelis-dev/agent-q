# Copy this file to .env.local for local zkLogin test runs.
# Vite exposes VITE_* values to browser code. Use only an Enoki public API key.
# Do not put Enoki private API keys, OAuth secrets, JWTs, or salts here.

VITE_ENOKI_API_URL=https://api.enoki.mystenlabs.com
VITE_ENOKI_PUBLIC_API_KEY=

# Optional Google OAuth client id for browser-side OIDC testing.
VITE_ZKLOGIN_GOOGLE_CLIENT_ID=

# Optional OAuth callback URL registered with the OAuth or Enoki app.
# Defaults to the bundled callback page when unset, for example
# http://127.0.0.1:5173/callback.html.
VITE_ZKLOGIN_REDIRECT_URI=
