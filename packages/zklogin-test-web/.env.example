# Copy this file to .env.local for local zkLogin test runs.
# Vite exposes VITE_* values to browser code; do not put private secrets here.

VITE_ENOKI_API_URL=https://api.enoki.mystenlabs.com
VITE_ENOKI_PUBLIC_API_KEY=

# Optional OAuth client id for browser-side OIDC testing.
VITE_ZKLOGIN_GOOGLE_CLIENT_ID=
